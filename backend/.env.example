# CodeRecall backend environment template.
# Copy this file to backend/.env and replace placeholder values as needed.
# Do not commit real API keys or production secrets.

# Display name used by the FastAPI app and health endpoint.
APP_NAME=CodeRecall API

# Runtime environment label returned by /health. Typical values: development, test, production.
APP_ENV=development

# Required outside APP_ENV=test. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-only-replace-this-with-a-generated-random-secret

# API route prefix for all versioned backend endpoints.
API_V1_PREFIX=/api/v1

# Host interface used when starting uvicorn locally.
BACKEND_HOST=0.0.0.0

# Port used when starting uvicorn locally.
BACKEND_PORT=8000

# Browser origin allowed by backend CORS middleware.
FRONTEND_ORIGIN=http://localhost:5173

# SQLAlchemy database URL. SQLite is the default local database.
DATABASE_URL=sqlite:///./coderecall.db

# ⚠️  SECURITY: Required outside APP_ENV=test. The placeholder below is rejected at startup.
# Generate a real value with:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
OLD_USER_INITIAL_PASSWORD=dev-only-replace-this-with-a-strong-password

# Set to true to enable streaming AI mistake analysis endpoints.
ENABLE_AI_ANALYSIS=false

# LLM provider identifier used by the backend AI analysis service.
LLM_PROVIDER=deepseek

# Default LLM model for routine analysis requests.
LLM_MODEL=deepseek-v4-pro

# Optional higher-capability model for premium or demo analysis flows.
LLM_MODEL_PREMIUM=deepseek-v4-pro

# API key for the configured LLM provider. Replace with a real value only in backend/.env.
LLM_API_KEY=replace-with-your-llm-api-key

# Base URL for the configured LLM provider or compatible proxy.
LLM_BASE_URL=https://api.deepseek.com/v1

# Comma-separated allowlist of model IDs accepted from client requests.
LLM_ALLOWED_MODELS=deepseek-v4-pro,deepseek-v4-flash

# Faster model used for non-reasoning tasks (e.g. variant generation). Falls back to LLM_MODEL if unset.
LLM_QUICK_MODEL=deepseek-v4-flash

# Toggle IP-based rate limiting on auth/AI/import endpoints. Keep true in production;
# CI/test fixtures override this automatically.
RATE_LIMIT_ENABLED=true
